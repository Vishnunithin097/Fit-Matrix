{
  "name": "fit-matrix-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Decoupled High-Speed Express/TypeScript Rule Engine for Fit Matrix Indian Fitness & Nutrition Ecosystem",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch ./server.ts",
    "clean": "node -e \"import('fs').then(fs => fs.rmSync('dist', { recursive: true, force: true }))\"",
    "build": "npm run clean && tsc",
    "start": "node dist/server.js"
  },
  "keywords": [
    "fit-matrix",
    "cyberpunk-fitness",
    "express-typescript",
    "ml-microservice-bridge"
  ],
  "author": "Vishnu Nithin P",
  "license": "ISC",
  "dependencies": {
    "@google/genai": "^1.0.0",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.6.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.0",
    "@types/cookie-parser": "^1.3.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.24",
    "@types/pg": "^8.5.4",
    "tsx": "^4.22.4",
    "typescript": "^5.3.3"
  }
}